$ErrorActionPreference = "Stop"

$folder = "$env:LOCALAPPDATA\PC_Check"
$exePath = "$folder\PC_Check.exe"
$url = "https://github.com/xybv/PC_Check_Echo/raw/main/PC_Check.exe"

# Create folder
if (!(Test-Path $folder)) {
    New-Item -ItemType Directory -Path $folder | Out-Null
}

# Download file
Write-Host "Downloading PC_Check..."
Invoke-WebRequest -Uri $url -OutFile $exePath

# Run it
Write-Host "Running PC_Check..."
Start-Process $exePath
